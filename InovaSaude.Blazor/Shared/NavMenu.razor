<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href=""><span class="oi oi-plus me-1"></span>InovaSaude</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">

        <AuthorizeView>
            <Authorized>
                <hr class="my-2" />
                <div class="px-3 mb-2">
                    <small class="text-muted text-uppercase">@context.User.FindFirst("perfil")?.Value</small>
                </div>

                <!-- Dashboard: todos os autenticados -->
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="dashboard">
                        <span class="oi oi-dashboard" aria-hidden="true"></span> Dashboard
                    </NavLink>
                </div>

                <!-- Despesas: ADMIN, COORDENADOR, GESTOR, OPERADOR -->
                <AuthorizeView Roles="ADMIN,COORDENADOR,GESTOR,OPERADOR" Context="despesasCtx">
                    <Authorized>
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="gerenciar-despesas">
                                <span class="oi oi-dollar" aria-hidden="true"></span> Despesas
                            </NavLink>
                        </div>
                    </Authorized>
                </AuthorizeView>

                <!-- ESF: ADMIN, COORDENADOR, GESTOR -->
                <AuthorizeView Roles="ADMIN,COORDENADOR,GESTOR" Context="esfCtx">
                    <Authorized>
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="gerenciar-esf">
                                <span class="oi oi-medical-cross" aria-hidden="true"></span> ESF
                            </NavLink>
                        </div>
                    </Authorized>
                </AuthorizeView>

                <!-- Relatorios: ADMIN, COORDENADOR, GESTOR, AUDITOR, VISUALIZADOR -->
                <AuthorizeView Roles="ADMIN,COORDENADOR,GESTOR,AUDITOR,VISUALIZADOR" Context="relCtx">
                    <Authorized>
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="relatorios-financeiros">
                                <span class="oi oi-bar-chart" aria-hidden="true"></span> Relatorios
                            </NavLink>
                        </div>
                    </Authorized>
                </AuthorizeView>

                <!-- Usuarios: somente ADMIN -->
                <AuthorizeView Roles="ADMIN" Context="userCtx">
                    <Authorized>
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="gerenciar-usuarios">
                                <span class="oi oi-people" aria-hidden="true"></span> Usuarios
                            </NavLink>
                        </div>
                    </Authorized>
                </AuthorizeView>

                <hr class="my-2" />

                <!-- Meu Perfil: todos os autenticados -->
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="meu-perfil">
                        <span class="oi oi-person" aria-hidden="true"></span> Meu Perfil
                    </NavLink>
                </div>

                <!-- Sair via GET: funciona sempre, sem depender de HttpClient ou CSRF -->
                <div class="nav-item px-3">
                    <a class="nav-link text-danger" href="/account/logout">
                        <span class="oi oi-account-logout" aria-hidden="true"></span> Sair
                    </a>
                </div>
            </Authorized>

            <NotAuthorized>
                <hr class="my-2" />
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="login">
                        <span class="oi oi-account-login" aria-hidden="true"></span> Entrar
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;
    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;
}
