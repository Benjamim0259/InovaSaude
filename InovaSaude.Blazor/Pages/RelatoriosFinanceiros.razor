@page "/relatorios-financeiros"
@using InovaSaude.Blazor.Services
@using InovaSaude.Blazor.Models
@using System.Globalization
@using System.Text
@inject DespesaService DespesaService
@inject FuncionarioService FuncionarioService
@inject ESFService ESFService
@inject CategoriaService CategoriaService
@inject PdfService PdfService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@attribute [Authorize]

<PageTitle>Relatórios Financeiros - InovaSaúde</PageTitle>

<div class="container-fluid mt-4">
    <!-- Cabeçalho -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><span class="oi oi-bar-chart me-2"></span>Relatorios Financeiros</h2>
        <div>
            <button class="btn btn-success me-1" @onclick="ExportarExcel" disabled="@carregando">
                <span class="oi oi-data-transfer-download me-2"></span>Excel
            </button>
            <button class="btn btn-danger" @onclick="ExportarPDF" disabled="@carregando">
                <span class="oi oi-document me-2"></span>PDF
            </button>
        </div>
    </div>

    <!-- Filtros Compactos -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row align-items-end g-3">
                <div class="col-md-3">
                    <label class="form-label fw-bold"><span class="oi oi-calendar me-1"></span>Mes Inicial</label>
                    <select class="form-select" @bind="mesInicio" @bind:after="CarregarDados">
                        @for (int i = -23; i <= 0; i++)
                        {
                            var mes = new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1).AddMonths(i);
                            var valor = mes.ToString("yyyy-MM");
                            <option value="@valor">@mes.ToString("MMMM/yyyy", new System.Globalization.CultureInfo("pt-BR"))</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold"><span class="oi oi-calendar me-1"></span>Mes Final</label>
                    <select class="form-select" @bind="mesFim" @bind:after="CarregarDados">
                        @for (int i = -23; i <= 0; i++)
                        {
                            var mes = new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1).AddMonths(i);
                            var valor = mes.ToString("yyyy-MM");
                            <option value="@valor">@mes.ToString("MMMM/yyyy", new System.Globalization.CultureInfo("pt-BR"))</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-bold"><span class="oi oi-medical-cross me-1"></span>Filtrar ESF</label>
                    <input type="text" class="form-control" placeholder="Pesquisar ESF..." 
                           @bind="pesquisaESF" @bind:after="StateHasChanged" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary w-100" @onclick="@(() => mostrarFiltroESF = !mostrarFiltroESF)">
                        <span class="oi oi-list me-1"></span>ESF (@esfIdsSelecionadas.Count)
                    </button>
                </div>
            </div>
            
            @if (mostrarFiltroESF)
            {
                <div class="mt-3 p-3 bg-light rounded" style="max-height: 300px; overflow-y: auto;">
                    <button class="btn btn-sm btn-outline-primary w-100 mb-3" @onclick="SelecionarTodasESF">
                        @(esfIdsSelecionadas.Count == esfList.Count ? "Desmarcar Todas" : "Selecionar Todas")
                    </button>
                    <div class="row g-2">
                        @foreach (var esf in esfList.Where(e => string.IsNullOrEmpty(pesquisaESF) || 
                                 e.Nome.Contains(pesquisaESF, StringComparison.OrdinalIgnoreCase) || 
                                 e.Codigo.Contains(pesquisaESF)).OrderBy(e => e.Nome))
                        {
                            <div class="col-md-4">
                                <div class="card @(esfIdsSelecionadas.Contains(esf.Id) ? "border-primary bg-primary bg-opacity-10" : "")" 
                                     style="cursor: pointer;" @onclick="@(() => ToggleESFCard(esf.Id))">
                                    <div class="card-body p-2">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" 
                                                   checked="@(esfIdsSelecionadas.Contains(esf.Id))"
                                                   @onclick:stopPropagation />
                                            <label class="form-check-label">
                                                <strong>@esf.Nome</strong><br />
                                                <small class="text-muted">CNES: @esf.Codigo</small>
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    @if (carregando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;"></div>
            <p class="mt-3">Carregando relatorios...</p>
        </div>
    }
    else
    {
        <!-- Cards de Resumo -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center h-100">
                    <div class="card-body">
                        <div class="display-6 mb-2"><span class="oi oi-dollar"></span></div>
                        <h3 class="text-danger mb-1">@totalDespesas.ToString("C", new CultureInfo("pt-BR"))</h3>
                        <p class="text-muted mb-0">Despesas</p>
                        <small class="text-muted">@quantidadeDespesas despesas</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center h-100">
                    <div class="card-body">
                        <div class="display-6 mb-2"><span class="oi oi-people"></span></div>
                        <h3 class="text-warning mb-1">@totalSalarios.ToString("C", new CultureInfo("pt-BR"))</h3>
                        <p class="text-muted mb-0">Salarios</p>
                        <small class="text-muted">@quantidadeFuncionarios funcionarios</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center h-100">
                    <div class="card-body">
                        <div class="display-6 mb-2"><span class="oi oi-bar-chart"></span></div>
                        <h3 class="text-primary mb-1">@((totalDespesas + totalSalarios).ToString("C", new CultureInfo("pt-BR")))</h3>
                        <p class="text-muted mb-0">Total Geral</p>
                        <small class="text-muted">@(esfIdsSelecionadas.Any() ? esfIdsSelecionadas.Count + " ESF" : "Todas ESF")</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center h-100">
                    <div class="card-body">
                        <div class="display-6 mb-2"><span class="oi oi-list"></span></div>
                        <h3 class="text-info mb-1">@despesasPorCategoria.Count</h3>
                        <p class="text-muted mb-0">Categorias</p>
                        <small class="text-muted">com despesas</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Abas de Navegacao -->
        <ul class="nav nav-tabs mb-4" role="tablist">
            <li class="nav-item">
                <button class="nav-link @(abaAtiva == "categorias" ? "active" : "")" 
                        @onclick='() => abaAtiva = "categorias"'>
                    <span class="oi oi-bar-chart me-2"></span>Por Categoria
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(abaAtiva == "esf" ? "active" : "")" 
                        @onclick='() => abaAtiva = "esf"'>
                    <span class="oi oi-medical-cross me-2"></span>Por ESF
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(abaAtiva == "evolucao" ? "active" : "")" 
                        @onclick='() => abaAtiva = "evolucao"'>
                    <span class="oi oi-graph me-2"></span>Evolucao Temporal
                </button>
            </li>
        </ul>

        <!-- Conteudo das Abas -->
        @if (abaAtiva == "categorias")
        {
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><span class="oi oi-bar-chart me-2"></span>Despesas por Categoria</h5>
                </div>
                <div class="card-body">
                    @foreach (var cat in despesasPorCategoria.OrderByDescending(x => x.Total))
                    {
                        var percentual = totalDespesas > 0 ? (cat.Total / totalDespesas * 100) : 0;
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span><strong>@cat.CategoriaNome</strong></span>
                                <span>@cat.Total.ToString("C", new CultureInfo("pt-BR")) (@percentual.ToString("F1")%)</span>
                            </div>
                            <div class="progress position-relative" style="height: 30px;">
                                <div class="progress-bar @GetCategoriaColor(cat.CategoriaNome)"
                                     style="width: @percentual.ToString("F1", CultureInfo.InvariantCulture)%; min-width: 2rem;">
                                </div>
                                <span class="position-absolute top-50 start-50 translate-middle fw-bold"
                                      style="color: #333; text-shadow: 0 0 4px #fff, 0 0 4px #fff;">
                                    @cat.Quantidade item@(cat.Quantidade != 1 ? "s" : "")
                                </span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else if (abaAtiva == "esf")
        {
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="card shadow-sm">
                        <div class="card-header bg-success text-white">
                            <h5 class="mb-0"><span class="oi oi-dollar me-2"></span>Despesas por ESF</h5>
                        </div>
                        <div class="card-body">
                            @foreach (var esf in despesasPorUBS.OrderByDescending(x => x.Total))
                            {
                                var percentual = totalDespesas > 0 ? (esf.Total / totalDespesas * 100) : 0;
                                <div class="mb-3">
                                    <div class="d-flex justify-content-between mb-1">
                                        <strong>@esf.UbsNome</strong>
                                        <span>@esf.Total.ToString("C", new CultureInfo("pt-BR"))</span>
                                    </div>
                                    <div class="progress" style="height: 25px;">
                                        <div class="progress-bar bg-success" style="width: @percentual.ToString("F1", CultureInfo.InvariantCulture)%">
                                            @esf.Quantidade item@(esf.Quantidade != 1 ? "s" : "")
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card shadow-sm">
                        <div class="card-header bg-warning">
                            <h5 class="mb-0"><span class="oi oi-people me-2"></span>Salarios por ESF</h5>
                        </div>
                        <div class="card-body">
                            @foreach (var esf in salariosPorUBS.OrderByDescending(x => x.TotalSalarios))
                            {
                                var percentual = totalSalarios > 0 ? (esf.TotalSalarios / totalSalarios * 100) : 0;
                                <div class="mb-3">
                                    <div class="d-flex justify-content-between mb-1">
                                        <strong>@esf.UbsNome</strong>
                                        <span>@esf.TotalSalarios.ToString("C", new CultureInfo("pt-BR"))</span>
                                    </div>
                                    <div class="progress" style="height: 25px;">
                                        <div class="progress-bar bg-warning" style="width: @percentual.ToString("F1", CultureInfo.InvariantCulture)%">
                                            @esf.QuantidadeFuncionarios pessoa@(esf.QuantidadeFuncionarios != 1 ? "s" : "")
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (abaAtiva == "evolucao")
        {
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><span class="oi oi-graph me-2"></span>Evolucao Mensal</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-start align-items-end" style="height: 300px; gap: 20px; overflow-x: auto; padding: 20px;">
                        @foreach (var mes in evolucaoMensal)
                        {
                            var maxValor = evolucaoMensal.Any() ? evolucaoMensal.Max(e => e.Total) : 1;
                            var altura = maxValor > 0 ? (mes.Total / maxValor * 250) : 0;
                            <div class="text-center" style="min-width: 100px;">
                                <div class="bg-gradient bg-primary rounded shadow" 
                                     style="height: @altura.ToString("F0")px; min-height: 20px; width: 80px;"
                                     title="@mes.Total.ToString("C", new CultureInfo("pt-BR"))">
                                </div>
                                <small class="d-block mt-2 fw-bold">@mes.Total.ToString("C0", new CultureInfo("pt-BR"))</small>
                                <small class="text-muted">@mes.MesNome</small>
                                <small class="d-block text-muted">@mes.Quantidade item@(mes.Quantidade != 1 ? "s" : "")</small>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<Despesa> todasDespesas = new();
    private List<ESF> esfList = new();
    private List<Categoria> categorias = new();
    private List<Funcionario> todosFuncionarios = new();

    private bool carregando = true;
    private bool mostrarFiltroESF = false;
    private string abaAtiva = "categorias";
    private string pesquisaESF = "";
    private List<string> esfIdsSelecionadas = new();

    private string mesInicio = new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1).AddMonths(-2).ToString("yyyy-MM");
    private string mesFim = new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1).ToString("yyyy-MM");

    private DateTime DataInicioParsed => DateTime.TryParseExact(mesInicio + "-01", "yyyy-MM-dd",
        System.Globalization.CultureInfo.InvariantCulture,
        System.Globalization.DateTimeStyles.None, out var d) ? DateTime.SpecifyKind(d, DateTimeKind.Utc) : DateTime.UtcNow.AddMonths(-2);

    private DateTime DataFimParsed => DateTime.TryParseExact(mesFim + "-01", "yyyy-MM-dd",
        System.Globalization.CultureInfo.InvariantCulture,
        System.Globalization.DateTimeStyles.None, out var d) ? DateTime.SpecifyKind(d.AddMonths(1).AddSeconds(-1), DateTimeKind.Utc) : DateTime.UtcNow;

    private decimal totalDespesas = 0;
    private int quantidadeDespesas = 0;
    private decimal totalSalarios = 0;
    private int quantidadeFuncionarios = 0;

    private List<DespesaPorCategoria> despesasPorCategoria = new();
    private List<DespesaPorUBS> despesasPorUBS = new();
    private List<SalarioPorUBS> salariosPorUBS = new();
    private List<EvolucaoMensal> evolucaoMensal = new();

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private void ToggleESFCard(string esfId)
    {
        if (esfIdsSelecionadas.Contains(esfId))
            esfIdsSelecionadas.Remove(esfId);
        else
            esfIdsSelecionadas.Add(esfId);
        CarregarDados();
    }

    private void SelecionarTodasESF()
    {
        if (esfIdsSelecionadas.Count == esfList.Count)
            esfIdsSelecionadas.Clear();
        else
            esfIdsSelecionadas = esfList.Select(e => e.Id).ToList();
        CarregarDados();
    }

    private async Task CarregarDados()
    {
        carregando = true;
        try
        {
            esfList = await ESFService.GetAllESFAsync() ?? new List<ESF>();
            categorias = await CategoriaService.GetAllCategoriasAsync() ?? new List<Categoria>();

            todasDespesas = await DespesaService.GetDespesasByPeriodoAsync(DataInicioParsed, DataFimParsed) ?? new List<Despesa>();
            if (esfIdsSelecionadas.Any())
                todasDespesas = todasDespesas.Where(d => esfIdsSelecionadas.Contains(d.EsfId)).ToList();

            todosFuncionarios = await FuncionarioService.GetAllAsync() ?? new List<Funcionario>();
            if (esfIdsSelecionadas.Any())
                todosFuncionarios = todosFuncionarios.Where(f => esfIdsSelecionadas.Contains(f.EsfId)).ToList();

            CalcularMetricas();
        }
        finally
        {
            carregando = false;
        }
    }

    private void CalcularMetricas()
    {
        totalDespesas = todasDespesas.Sum(d => d.Valor);
        quantidadeDespesas = todasDespesas.Count;
        totalSalarios = todosFuncionarios.Sum(f => f.Salario);
        quantidadeFuncionarios = todosFuncionarios.Count;

        despesasPorCategoria = todasDespesas
            .GroupBy(d => d.Categoria?.Nome ?? "Sem Categoria")
            .Select(g => new DespesaPorCategoria
            {
                CategoriaNome = g.Key,
                Total = g.Sum(d => d.Valor),
                Quantidade = g.Count()
            })
            .ToList();

        despesasPorUBS = todasDespesas
            .GroupBy(d => d.Esf?.Nome ?? "Sem ESF")
            .Select(g => new DespesaPorUBS
            {
                UbsNome = g.Key,
                Total = g.Sum(d => d.Valor),
                Quantidade = g.Count()
            })
            .ToList();

        salariosPorUBS = todosFuncionarios
            .GroupBy(f => f.Esf?.Nome ?? "Sem ESF")
            .Select(g => new SalarioPorUBS
            {
                UbsNome = g.Key,
                TotalSalarios = g.Sum(f => f.Salario),
                QuantidadeFuncionarios = g.Count()
            })
            .ToList();

        evolucaoMensal = todasDespesas
            .GroupBy(d => new { d.MesReferencia.Year, d.MesReferencia.Month })
            .Select(g => new EvolucaoMensal
            {
                Ano = g.Key.Year,
                Mes = g.Key.Month,
                MesNome = new DateTime(g.Key.Year, g.Key.Month, 1).ToString("MMM/yy", new CultureInfo("pt-BR")),
                Total = g.Sum(d => d.Valor),
                Quantidade = g.Count()
            })
            .OrderBy(e => e.Ano).ThenBy(e => e.Mes)
            .ToList();
    }

    private string GetCategoriaColor(string categoria) => categoria switch
    {
        "Farmacia" => "bg-danger",
        "Material Medico" => "bg-primary",
        "Contas Fixas" => "bg-warning",
        "Pessoal" => "bg-success",
        "Infraestrutura" => "bg-secondary",
        "Servicos Terceirizados" => "bg-info",
        "Alimentacao" => "bg-success",
        _ => "bg-dark"
    };

    private async Task ExportarExcel()
    {
        try
        {
            var csv = new StringBuilder();
            csv.AppendLine("Mes Referencia;Descricao;ESF;Categoria;Fornecedor;Valor");

            foreach (var despesa in todasDespesas.OrderBy(d => d.MesReferencia))
            {
                csv.AppendLine($"{despesa.MesReferencia:MM/yyyy};{despesa.Descricao};{despesa.Esf?.Nome};{despesa.Categoria?.Nome};{despesa.Fornecedor?.NomeFantasia ?? despesa.Fornecedor?.RazaoSocial};{despesa.Valor:F2}");
            }

            csv.AppendLine();
            csv.AppendLine("SALARIOS");
            csv.AppendLine("Nome;ESF;Cargo;Salario");
            foreach (var func in todosFuncionarios.OrderBy(f => f.Esf?.Nome).ThenBy(f => f.Nome))
            {
                csv.AppendLine($"{func.Nome};{func.Esf?.Nome};{func.Cargo};{func.Salario:F2}");
            }

            var bytes = Encoding.UTF8.GetBytes(csv.ToString());
            var base64 = Convert.ToBase64String(bytes);
            var filename = $"relatorio-{mesInicio}-a-{mesFim}.csv";

            await JSRuntime.InvokeVoidAsync("downloadFile", filename, base64, "text/csv");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Erro ao exportar: {ex.Message}");
        }
    }

    private async Task ExportarPDF()
    {
        try
        {
            var pdfBytes = PdfService.GerarRelatorioPDF(
                todasDespesas,
                todosFuncionarios,
                DataInicioParsed,
                DataFimParsed,
                totalDespesas,
                totalSalarios
            );

            var base64 = Convert.ToBase64String(pdfBytes);
            var filename = $"relatorio-{mesInicio}-a-{mesFim}.pdf";

            await JSRuntime.InvokeVoidAsync("downloadFile", filename, base64, "application/pdf");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Erro ao gerar PDF: {ex.Message}");
        }
    }

    public class DespesaPorCategoria
    {
        public string CategoriaNome { get; set; } = "";
        public decimal Total { get; set; }
        public int Quantidade { get; set; }
    }

    public class DespesaPorUBS
    {
        public string UbsNome { get; set; } = "";
        public decimal Total { get; set; }
        public int Quantidade { get; set; }
    }

    public class SalarioPorUBS
    {
        public string UbsNome { get; set; } = "";
        public decimal TotalSalarios { get; set; }
        public int QuantidadeFuncionarios { get; set; }
    }

    public class EvolucaoMensal
    {
        public int Ano { get; set; }
        public int Mes { get; set; }
        public string MesNome { get; set; } = "";
        public decimal Total { get; set; }
        public int Quantidade { get; set; }
    }
}
